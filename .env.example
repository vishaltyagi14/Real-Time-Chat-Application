# Environment Configuration File
# Copy this to .env and update values for your environment

# Node Environment
NODE_ENV=development

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/rtl

# JWT Secret Key (use strong random string in production)
JWT_KEY=your-super-secret-jwt-key-change-this-in-production

# Cookie Secret (use strong random string in production)
COOKIE_SECRET=your-super-secret-cookie-key-change-this-in-production

# Email Configuration (for OTP)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# Mail Service (gmail, outlook, etc)
MAIL_SERVICE=gmail

# Server Port
PORT=3000

# Session Config
SESSION_TIMEOUT=10 # minutes for OTP expiry

# CORS Settings (if needed)
CORS_ORIGIN=http://localhost:3000

# Rate Limiting (optional)
RATE_LIMIT_WINDOW=15 # minutes
RATE_LIMIT_MAX_REQUESTS=100

# Log Level
LOG_LEVEL=info
