<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>
    <link rel="stylesheet" href="/stylesheets/home.css">
</head>
<body>
    <!-- Navbar Section -->
    <div class="navbar">
        <div class="logo">
            <div class="logo" style="background-color: white;
            width: 50px;
            border-radius: 12px;
            height: 50px;
            display: flex;
            justify-content: center;
            align-items: center;">
                <img style="height: 25px;
            filter: brightness(0) saturate(100%) invert(38%) sepia(98%) saturate(2000%) hue-rotate(215deg); cursor: pointer;" src="images/chat.png" alt="">
            </div>
            <h2>ChatApp</h2>
        </div>
        <div id="navLoginBtn"><a href="/login" style="text-decoration: none; color: white;">Log In</a></div>
    </div>

    <!-- Main Section -->
     <div class="main">
        <div class="intro">
            <div class="introLogo">
                <img style="height: 40px; filter: brightness(0) saturate(100%) invert(38%) sepia(98%) saturate(2000%) hue-rotate(215deg);" src="images/chat.png" alt="">
            </div>

            <div id="heading">
                <h1 id="introHeading">Connect With <span id="introHeading2">Everyone</span></h1>
            </div>

            <div id="para"><p id="introPara">Fast, secure, and reliable messaging for everyone. Stay connected with friends and family anytime, anywhere.</p>
            </div>

            <div class="auth">
                <a href="/signup" id="signupBtn">Get Started Free &nbsp;<span id="arrow">→</span></a>
                <a href="/login" id="loginBtn">Log In</a>
            </div>
        </div>

        <div class="cards">
            <div class="card">
                
                <div class="cardLogo">
                    <img class="cardimg" src="images/lighting.png" alt="">
                </div>
                <div class="cardHeading">
                    <h1>Lightning Fast</h1>
                </div>
                <div class="cardPara">
                    <p>Messages delivered instantly with real-time synchronization</p>
                </div>

            </div>
            <div class="card">
                
                <div class="cardLogo">
                    <img class="cardimg" src="images/shield.png" alt="">
                </div>
                <div class="cardHeading">
                    <h1>Secure & Private</h1>
                </div>
                <div class="cardPara">
                    <p>End-to-end encryption keeps your conversations private</p>
                </div>

            </div>
            <div class="card">
                
                <div class="cardLogo">
                    <img class="cardimg" src="images/user.png" alt="">
                </div>
                <div class="cardHeading">
                    <h1>Stay Connected</h1>
                </div>
                <div class="cardPara">
                    <p>Chat with unlimited contacts and create group conversations</p>
                </div>

            </div>
        </div>
     </div>
     <!-- Footer Section -->
    <div class="footer">
        © 2026 ChatApp. All Rights Reserved
    </div>
</body>
</html>